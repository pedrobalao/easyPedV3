# easyPed Environment Variables
# Copy this file to .env and fill in the values

# API base URL for the easyPed backend
API_BASE_URL=

# Google OAuth Client ID (used for Firebase Google Sign-In)
GOOGLE_CLIENT_ID=

# RevenueCat API keys for in-app subscription management
REVENUECAT_APPLE_API_KEY=
REVENUECAT_GOOGLE_API_KEY=
